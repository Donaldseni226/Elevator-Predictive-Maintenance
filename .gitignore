# Arduino IDE and ESP32 specific ignore patterns

# Arduino build results
*.o
*.d
*.a
*.elf
*.hex
*.eep
*.bin
*.map
*.lss

# Arduino IDE configuration files
.arduino_cache/
.arduino15/
.libraries/

# ESP32-specific files
*.part
*.bin
*.elf

# Binaries and Executables
*.exe
*.out
*.app
*.dmg
*.apk

# Temporary files
*.tmp
*.temp
*.log